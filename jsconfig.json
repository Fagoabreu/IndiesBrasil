{
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "infra/*": ["./infra/*"],
      "models/*": ["./models/*"],
      "lib/*": ["./lib/*"],
      "utils/*": ["./utils/*"],
      "context/*": ["./context/*"]
    },
    "jsx": "react-jsx",
    "module": "CommonJS",
    "target": "ES6"
  },
  "exclude": ["node_modules"]
}
