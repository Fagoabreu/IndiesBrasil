{
  "name": "indiesbrasil",
  "version": "0.0.0",
  "description": "Portal dos desenvolvedores indie",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run Services:wait:database && npm run migrations:up && next dev",
    "test": "npm run services:up && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand --verbose\"",
    "posttest": "npm run services:stop",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "Services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "npx node-pg-migrate -m infra/migrations --envPath .env.development up",
    "build": "next build",
    "lint": "eslint .",
    "lint:eslint:check": "eslint . --max-warnings=0",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "prepare": "husky",
    "commit": "cz"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fagoabreu/IndiesBrasil.git"
  },
  "author": "Fabio Gomes de Abreu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Fagoabreu/IndiesBrasil/issues"
  },
  "homepage": "https://github.com/Fagoabreu/IndiesBrasil#readme",
  "dependencies": {
    "@primer/primitives": "11.2.1",
    "@primer/react": "38.0.0",
    "async-retry": "1.3.3",
    "bcryptjs": "3.0.3",
    "bootstrap": "5.3.5",
    "cloudinary": "^2.8.0",
    "cookie": "1.1.1",
    "next": "16.2.9",
    "next-cloudinary": "6.17.5",
    "next-connect": "1.0.0-next.4",
    "nodemailer": "9.0.1",
    "pg": "8.20.0",
    "prop-types": "15.8.1",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "5.5.6",
    "styled-components": "6.4.3",
    "swr": "2.4.1",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/css": "1.0.0",
    "@eslint/js": "9.39.4",
    "@eslint/json": "1.1.0",
    "@eslint/markdown": "7.5.1",
    "@faker-js/faker": "9.7.0",
    "@types/jest": "30.0.0",
    "commitizen": "4.3.2",
    "concurrently": "9.2.3",
    "cz-conventional-changelog": "3.3.0",
    "dotenv": "16.4.7",
    "dotenv-expand": "12.0.3",
    "eslint": "9.39.3",
    "eslint-config-next": "16.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.0",
    "eslint-plugin-primer-react": "8.5.2",
    "faker-br": "0.4.1",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "inquirer": "^13.3.0",
    "jest": "30.4.2",
    "node-pg-migrate": "^8.0.4",
    "prettier": "3.8.1",
    "set-cookie-parser": "3.0.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "engines": {
    "node": "24"
  },
  "overrides": {
    "postcss": "8.5.10",
    "js-yaml": "4.3.0"
  },
  "allowScripts": {
    "sharp": true,
    "unrs-resolver": true
  }
}
